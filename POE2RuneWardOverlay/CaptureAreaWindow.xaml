<Window x:Class="POE2RuneWardOverlay.CaptureAreaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        MinWidth="168" MinHeight="52">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="22"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="88"/>
        </Grid.ColumnDefinitions>

        <!-- 좌표 레이블 (테두리 위, 바깥쪽) -->
        <TextBlock x:Name="CoordLabel"
                   Grid.Row="0" Grid.Column="0"
                   VerticalAlignment="Center" HorizontalAlignment="Left"
                   Margin="2,0,0,0"
                   Background="#CC000000" Foreground="White"
                   FontSize="10" Padding="4,1"/>

        <!-- 드래그 가능한 캡처 영역 -->
        <Border Grid.Row="1" Grid.Column="0"
                BorderBrush="#FF6600" BorderThickness="2"
                Background="#22FF6600"
                MouseLeftButtonDown="OnDrag"
                Cursor="SizeAll"/>

        <!-- 우하단 크기 조절 핸들 -->
        <Thumb Grid.Row="1" Grid.Column="0"
               VerticalAlignment="Bottom" HorizontalAlignment="Right"
               Width="14" Height="14" Cursor="SizeNWSE"
               DragDelta="OnResizeDelta">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Rectangle Fill="#FF6600" Opacity="0.9" RadiusX="2" RadiusY="2"/>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <!-- 완료 버튼 (두 행 모두에 걸쳐 우측) -->
        <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                Content="완료"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="16,6" FontSize="12" Foreground="White"
                Cursor="Arrow" Click="OnConfirm">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="#CC000000" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#DD222222"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#EE444444"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
