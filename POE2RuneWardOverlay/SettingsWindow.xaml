<Window x:Class="POE2RuneWardOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="룬수호 오버레이 설정" Width="370"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <StackPanel Margin="20">

        <TextBlock Text="위험 임계값" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Slider x:Name="ThresholdSlider" Minimum="5" Maximum="60" Width="240"
                    TickFrequency="5" IsSnapToTickEnabled="True"
                    ValueChanged="OnThresholdChanged"/>
            <TextBlock x:Name="ThresholdLabel" Margin="8,0,0,0" VerticalAlignment="Center" Width="40"/>
        </StackPanel>

        <TextBlock Text="수호 최대치" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <TextBox x:Name="MaxWard" Width="80" Margin="0,0,8,0"/>
            <TextBlock Text="0 입력 시 OCR 자동 감지" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock Text="현재값이 최대치×1.5 초과이면 OCR 오인식으로 간주해 무시"
                   FontSize="11" Foreground="#888" Margin="0,0,0,16"/>

        <TextBlock Text="캡처 영역 (좌측 하단 룬수호 텍스트)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="16"/><ColumnDefinition Width="55"/>
                <ColumnDefinition Width="8"/><ColumnDefinition Width="16"/><ColumnDefinition Width="55"/>
                <ColumnDefinition Width="8"/><ColumnDefinition Width="16"/><ColumnDefinition Width="55"/>
                <ColumnDefinition Width="8"/><ColumnDefinition Width="16"/><ColumnDefinition Width="55"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="X" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox x:Name="CaptureX" Grid.Column="1" Margin="2"/>
            <TextBlock Text="Y" Grid.Column="3" VerticalAlignment="Center"/>
            <TextBox x:Name="CaptureY" Grid.Column="4" Margin="2"/>
            <TextBlock Text="W" Grid.Column="6" VerticalAlignment="Center"/>
            <TextBox x:Name="CaptureW" Grid.Column="7" Margin="2"/>
            <TextBlock Text="H" Grid.Column="9" VerticalAlignment="Center"/>
            <TextBox x:Name="CaptureH" Grid.Column="10" Margin="2"/>
        </Grid>
        <TextBlock Text="기본값: X=20, Y=832, W=220, H=35"
                   FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
        <TextBlock Text="이동: Ctrl+Shift+M (황금 테두리 = 이동 모드)"
                   FontSize="11" Foreground="#888" Margin="0,0,0,8"/>
        <Button Content="캡처 영역 미리보기 (3초)" HorizontalAlignment="Left"
                Margin="0,0,0,16" Click="OnPreview"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="저장" Width="80" Margin="0,0,8,0" Click="OnSave"/>
            <Button Content="취소" Width="80" Click="OnCancel"/>
        </StackPanel>
    </StackPanel>
</Window>
