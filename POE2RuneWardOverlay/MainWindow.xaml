<Window x:Class="POE2RuneWardOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="POE2 룬수호 오버레이"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight">

    <Border x:Name="RootBorder"
            Background="#B2000000"
            CornerRadius="6"
            Padding="12,7"
            MouseLeftButtonDown="OnMouseLeftButtonDown"
            Cursor="SizeAll">
        <Border.LayoutTransform>
            <ScaleTransform x:Name="OverlayScale" ScaleX="1" ScaleY="1"/>
        </Border.LayoutTransform>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

            <TextBlock x:Name="LabelText"
                       Text="룬수호"
                       Foreground="#AAAAAA"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <Canvas Width="189" Height="14" VerticalAlignment="Center" Margin="0,0,8,0">
                <Rectangle Width="144" Height="14" RadiusX="3" RadiusY="3" Fill="#33FFFFFF"/>
                <Rectangle x:Name="MainBar" Height="14" RadiusX="3" RadiusY="3" Width="0"/>
                <Rectangle x:Name="OverflowBar" Height="14" RadiusX="0" RadiusY="3"
                           Fill="#FFCC44" Canvas.Left="144" Width="0"/>
            </Canvas>

            <TextBlock x:Name="ValueText"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       />
        </StackPanel>
    </Border>
</Window>
